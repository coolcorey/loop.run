# --- Client (Vite) ---
# mock | xai (default: xai — uses API with mock fallback)
VITE_AI_PROVIDER=xai

# Leave empty in dev to use Vite proxy → http://127.0.0.1:8787
# VITE_API_BASE=

# Optional MapLibre style URL (default: OpenFreeMap dark)
# VITE_MAP_STYLE=https://tiles.openfreemap.org/styles/dark
# VITE_MAP_STYLE=https://tiles.openfreemap.org/styles/liberty

# VITE_POCKETBASE_URL=http://127.0.0.1:8090

# --- Server only (never VITE_ — keeps keys off the client) ---
PORT=8787

# xAI Grok — https://console.x.ai/
XAI_API_KEY=
XAI_MODEL=grok-4.3
# XAI_BASE_URL=https://api.x.ai/v1

# OpenRouteService foot routing (https://openrouteservice.org/) — preferred when set
# Without this, public OSRM foot routing is used (rate-limited / best-effort)
# Foot profile already skips motorways; ferries/fords avoided in code.
# ORS_API_KEY=

# Optional self-hosted OSRM
# OSRM_URL=https://router.project-osrm.org
