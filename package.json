{
  "name": "loop.run",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n api,web -c cyan,magenta \"npm:dev:api\" \"npm:dev:web\"",
    "dev:web": "vite",
    "dev:api": "tsx server/index.ts",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "start:api": "tsx server/index.ts"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.8",
    "concurrently": "^10.0.3",
    "hono": "^4.12.28",
    "maplibre-gl": "^5.24.0",
    "pinia": "^3.0.4",
    "pocketbase": "^0.27.0",
    "vue": "^3.5.39",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/tsconfig": "^0.9.1",
    "tsx": "^4.23.0",
    "typescript": "~6.0.2",
    "vite": "^6.4.3",
    "vite-plugin-pwa": "^1.3.0",
    "vue-tsc": "^3.3.5"
  }
}
